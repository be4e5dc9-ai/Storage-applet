.user-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999;
}

.user-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-card.stat-warning {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-warning .stat-num {
  color: #fa8c16;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-icon-scan {
  background: #e6f7ff;
}

.action-icon-add {
  background: #f6ffed;
}

.action-icon-cat {
  background: #fff7e6;
}

.action-icon-record {
  background: #f9f0ff;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.warning-list {
  border-top: 1rpx solid #f0f0f0;
}

.warning-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.warning-item:last-child {
  border-bottom: none;
}

.warning-info {
  display: flex;
  flex-direction: column;
}

.warning-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.warning-stock {
  font-size: 24rpx;
}

.warning-action {
  padding-left: 20rpx;
}

.record-list {
  border-top: 1rpx solid #f0f0f0;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-type {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 16rpx;
}

.type-in {
  background: #52c41a;
}

.type-out {
  background: #ff4d4f;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.record-quantity {
  font-size: 32rpx;
  font-weight: 600;
}

.login-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.login-modal {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.role-selector {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  padding: 20rpx 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.role-item.role-active {
  border-color: #1890ff;
  background: #e6f7ff;
}

.role-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.role-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.login-btn {
  margin-top: 30rpx;
  width: 100%;
}