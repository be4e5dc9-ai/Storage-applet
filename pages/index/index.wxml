<view class="container">
  <!-- 用户信息栏 -->
  <view class="user-bar card" bindtap="onUserBarTap">
    <view class="user-avatar">
      <text class="avatar-text">{{userInfo.name[0] || '访'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未登录'}}</text>
      <text class="user-role">{{roleName || '点击登录'}}</text>
    </view>
    <view class="user-arrow">›</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card" bindtap="goToGoodsList">
      <text class="stat-num">{{stats.totalGoods}}</text>
      <text class="stat-label">货物种类</text>
    </view>
    <view class="stat-card" bindtap="goToGoodsList">
      <text class="stat-num">{{stats.totalStock}}</text>
      <text class="stat-label">总库存量</text>
    </view>
    <view class="stat-card {{stats.lowStockCount > 0 ? 'stat-warning' : ''}}" bindtap="goToLowStock">
      <text class="stat-num">{{stats.lowStockCount}}</text>
      <text class="stat-label">库存预警</text>
    </view>
    <view class="stat-card" bindtap="goToRecords">
      <text class="stat-num">{{stats.todayRecordCount}}</text>
      <text class="stat-label">今日操作</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="card">
    <view class="section-title">快捷操作</view>
    <view class="action-grid">
      <view class="action-item" bindtap="goToScan">
        <view class="action-icon action-icon-scan">📷</view>
        <text class="action-text">扫码入库</text>
      </view>
      <view class="action-item" bindtap="goToAddGoods">
        <view class="action-icon action-icon-add">➕</view>
        <text class="action-text">新增货物</text>
      </view>
      <view class="action-item" bindtap="goToCategory">
        <view class="action-icon action-icon-cat">📂</view>
        <text class="action-text">分类管理</text>
      </view>
      <view class="action-item" bindtap="goToRecords">
        <view class="action-icon action-icon-record">📋</view>
        <text class="action-text">操作记录</text>
      </view>
    </view>
  </view>

  <!-- 库存预警 -->
  <view class="card" wx:if="{{stats.lowStockGoods.length > 0}}">
    <view class="flex-between mb-20">
      <text class="section-title" style="margin-bottom:0">⚠️ 库存预警</text>
      <text class="text-primary text-sm" bindtap="goToLowStock">查看全部</text>
    </view>
    <view class="warning-list">
      <view class="warning-item" wx:for="{{stats.lowStockGoods}}" wx:key="id" bindtap="goToGoodsDetail" data-id="{{item.id}}">
        <view class="warning-info">
          <text class="warning-name">{{item.name}}</text>
          <text class="warning-stock text-danger">剩余 {{item.stock}} 件</text>
        </view>
        <view class="warning-action">
          <text class="text-primary text-sm">去入库 ›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近操作 -->
  <view class="card" wx:if="{{stats.recentRecords.length > 0}}">
    <view class="flex-between mb-20">
      <text class="section-title" style="margin-bottom:0">📝 最近操作</text>
      <text class="text-primary text-sm" bindtap="goToRecords">查看全部</text>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{stats.recentRecords}}" wx:key="id" bindtap="goToRecordDetail" data-id="{{item.id}}">
        <view class="record-type {{item.type === 'in' ? 'type-in' : 'type-out'}}">
          {{item.type === 'in' ? '入' : '出'}}
        </view>
        <view class="record-info">
          <text class="record-name">{{item.goodsName}}</text>
          <text class="record-time">{{item.timeAgo}}</text>
        </view>
        <view class="record-quantity">
          <text class="{{item.type === 'in' ? 'text-success' : 'text-danger'}}">
            {{item.type === 'in' ? '+' : '-'}}{{item.quantity}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录弹窗 -->
  <view class="login-mask" wx:if="{{showLogin}}" catchtap="hideLogin">
    <view class="login-modal" catchtap="preventBubble">
      <view class="login-title">用户登录</view>
      <view class="form-group">
        <text class="form-label">用户名</text>
        <input class="form-input" placeholder="请输入用户名" value="{{loginForm.name}}" bindinput="onLoginInput" data-field="name" />
      </view>
      <view class="form-group">
        <text class="form-label">角色</text>
        <view class="role-selector">
          <view class="role-item {{loginForm.role === item.value ? 'role-active' : ''}}"
                wx:for="{{roles}}" wx:key="value"
                bindtap="selectRole" data-role="{{item.value}}">
            <text class="role-name">{{item.label}}</text>
            <text class="role-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <button class="btn-primary login-btn" bindtap="doLogin">确认登录</button>
    </view>
  </view>
</view>