.filter-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  flex: 1;
  gap: 12rpx;
}

.filter-tab {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-tab.tab-active {
  color: #fff;
  background: #1890ff;
}

.filter-date {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid #e8e8e8;
}

.date-picker {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.date-clear {
  font-size: 24rpx;
  color: #999;
  padding: 10rpx;
  margin-left: 8rpx;
}

.stats-card {
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.record-list {
  padding-bottom: 20rpx;
}

.record-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-type {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

.record-type.type-in {
  background: #52c41a;
}

.record-type.type-out {
  background: #ff4d4f;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-goods {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.goods-barcode {
  font-size: 24rpx;
  color: #999;
}

.record-quantity {
  font-size: 40rpx;
  font-weight: 700;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stock-change {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.stock-arrow {
  color: #ccc;
}

.record-operator {
  font-size: 24rpx;
  color: #999;
}

.record-remark {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.remark-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.remark-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}