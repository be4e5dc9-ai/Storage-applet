.type-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.header-in {
  background: linear-gradient(135deg, #f6ffed, #d9f7be);
}

.header-out {
  background: linear-gradient(135deg, #fff1f0, #ffa39e);
}

.type-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.8);
}

.type-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.type-time {
  font-size: 26rpx;
  color: #666;
}

.quantity-card {
  text-align: center;
}

.quantity-display {
  margin-bottom: 30rpx;
}

.quantity-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.quantity-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.stock-change {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.stock-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stock-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stock-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stock-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.detail-list {
  border-top: 1rpx solid #f0f0f0;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.record-id {
  font-size: 22rpx;
  color: #999;
  word-break: break-all;
  max-width: 400rpx;
}

.detail-link {
  display: flex;
  align-items: center;
}

.link-text {
  font-size: 28rpx;
  color: #1890ff;
  margin-right: 8rpx;
}

.link-arrow {
  font-size: 28rpx;
  color: #1890ff;
}

.remark-content {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 0 60rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}