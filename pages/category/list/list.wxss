.category-list {
  padding-bottom: 140rpx;
}

.category-item {
  padding: 0;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.category-main {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #f0f9ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.category-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

.category-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.category-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #1890ff;
  background: #fff;
}

.action-btn:active {
  background: #f5f5f5;
}

.action-btn-danger {
  color: #ff4d4f;
  border-left: 1rpx solid #f0f0f0;
}

.add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.add-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}