.icon-selector {
  display: flex;
  align-items: center;
}

.selected-icon {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
}

.icon-display {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.icon-hint {
  font-size: 28rpx;
  color: #999;
}

.icon-picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  border: 1rpx solid #e8e8e8;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 16rpx;
}

.icon-item {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.icon-item.icon-active {
  border-color: #1890ff;
  background: #e6f7ff;
}

.icon-item:active {
  transform: scale(0.95);
}

.form-error {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  display: block;
}

.submit-bar {
  padding: 30rpx 0 60rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
}