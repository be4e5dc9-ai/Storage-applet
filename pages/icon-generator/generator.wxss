.desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  display: block;
}

.icon-canvas {
  width: 200rpx;
  height: 200rpx;
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.status-list {
  border-top: 1rpx solid #f0f0f0;
}

.status-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 22rpx;
}

.status-success {
  background: #52c41a;
  color: #fff;
}

.status-pending {
  background: #f0f0f0;
  color: #999;
}

.status-name {
  font-size: 28rpx;
  color: #333;
}

.help-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}