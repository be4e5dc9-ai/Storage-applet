.filter-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.filter-active {
  color: #fff;
  background: #1890ff;
}

.filter-status {
  margin-left: 16rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid #e8e8e8;
}

.status-picker {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.goods-list {
  padding-bottom: 120rpx;
}

.goods-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.goods-header {
  margin-bottom: 16rpx;
}

.goods-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.goods-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
  flex: 1;
}

.goods-category {
  font-size: 24rpx;
  color: #999;
}

.goods-body {
  margin-bottom: 16rpx;
}

.goods-info-row {
  display: flex;
  justify-content: space-between;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.goods-time {
  font-size: 22rpx;
  color: #bbb;
}

.goods-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #1890ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #e6f7ff;
}

.action-btn-danger {
  color: #ff4d4f;
  background: #fff1f0;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}