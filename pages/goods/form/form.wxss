.barcode-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.scan-btn {
  white-space: nowrap;
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  line-height: 80rpx;
  color: #333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.stock-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-stock {
  width: 80rpx;
  height: 80rpx;
  line-height: 76rpx;
  text-align: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  font-size: 36rpx;
  color: #666;
  padding: 0;
  margin: 0;
}

.btn-stock::after {
  border: none;
}

.stock-input {
  flex: 1;
  text-align: center;
}

.form-error {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  display: block;
}

.submit-bar {
  padding: 30rpx 0 60rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
}