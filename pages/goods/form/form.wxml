<view class="container">
  <view class="card">
    <view class="section-title">{{isEdit ? '编辑货物' : '新增货物'}}</view>

    <!-- 货物名称 -->
    <view class="form-group">
      <text class="form-label">货物名称 *</text>
      <input class="form-input" placeholder="请输入货物名称" value="{{form.name}}" bindinput="onInput" data-field="name" />
      <text class="form-error" wx:if="{{errors.name}}">{{errors.name}}</text>
    </view>

    <!-- 条形码 -->
    <view class="form-group">
      <text class="form-label">条形码</text>
      <view class="barcode-row">
        <input class="form-input" style="flex:1" placeholder="请输入或扫描条形码" value="{{form.barcode}}" bindinput="onInput" data-field="barcode" />
        <button class="btn-outline scan-btn" bindtap="scanBarcode">📷 扫码</button>
      </view>
    </view>

    <!-- 分类 -->
    <view class="form-group">
      <text class="form-label">货物分类</text>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}" range-key="name">
        <view class="form-input picker-input">
          {{form.categoryName || '请选择分类'}}
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
    </view>

    <!-- 价格 -->
    <view class="form-group">
      <text class="form-label">单价 (元)</text>
      <input class="form-input" type="digit" placeholder="请输入单价" value="{{form.price}}" bindinput="onInput" data-field="price" />
    </view>

    <!-- 库存数量 -->
    <view class="form-group">
      <text class="form-label">{{isEdit ? '调整库存' : '初始库存'}}</text>
      <view class="stock-row" wx:if="{{isEdit}}">
        <button class="btn-stock" bindtap="adjustStock" data-amount="{{-1}}">-</button>
        <input class="form-input stock-input" type="number" value="{{form.stock}}" bindinput="onInput" data-field="stock" />
        <button class="btn-stock" bindtap="adjustStock" data-amount="{{1}}">+</button>
      </view>
      <input class="form-input" type="number" placeholder="请输入初始库存数量" value="{{form.stock}}" bindinput="onInput" data-field="stock" wx:else />
    </view>

    <!-- 最低库存预警 -->
    <view class="form-group">
      <text class="form-label">最低库存预警</text>
      <input class="form-input" type="number" placeholder="低于此数量将发出预警" value="{{form.minStock}}" bindinput="onInput" data-field="minStock" />
    </view>

    <!-- 单位 -->
    <view class="form-group">
      <text class="form-label">计量单位</text>
      <input class="form-input" placeholder="如：件、箱、个" value="{{form.unit}}" bindinput="onInput" data-field="unit" />
    </view>

    <!-- 规格 -->
    <view class="form-group">
      <text class="form-label">规格型号</text>
      <input class="form-input" placeholder="如：500ml、XL" value="{{form.spec}}" bindinput="onInput" data-field="spec" />
    </view>

    <!-- 描述 -->
    <view class="form-group">
      <text class="form-label">货物描述</text>
      <textarea class="form-textarea" placeholder="请输入货物描述信息" value="{{form.description}}" bindinput="onInput" data-field="description" maxlength="500" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <button class="btn-primary submit-btn" bindtap="onSubmit" loading="{{submitting}}">
      {{isEdit ? '保存修改' : '确认添加'}}
    </button>
  </view>
</view>